# ==========================================
# AuraChat AI — Environment Configurations Template
# ==========================================

ENVIRONMENT=production

# --- Database Configurations ---
DATABASE_URL=sqlite:///./aurachat.db

# --- Redis Configurations ---
# Leave empty to default to thread-safe local in-memory storage
REDIS_URL=

# --- Vector Database Configurations ---
# Leave empty to default to local persistent client
CHROMA_SERVER_HOST=
CHROMA_SERVER_PORT=8000
CHROMA_PERSIST_DIR=./chroma_db

# --- CORS & Integration URLs ---
# Next.js API URL to locate the FastAPI backend
NEXT_PUBLIC_API_URL=https://aurachat-backend.onrender.com

# FastAPI CORS dynamic URL to locate the Next.js frontend
FRONTEND_URL=https://aurachat-frontend.vercel.app
