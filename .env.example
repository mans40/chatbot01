# ==========================================
# SupportIQ AI — Environment Configurations
# ==========================================

# Environment Mode (development | production)
ENVIRONMENT=development

# --- OpenAI Configuration ---
# Required for LangChain and GPT-4o-mini responses
OPENAI_API_KEY=your_openai_api_key_here

# --- Database Configurations ---
# Set to use local SQLite during dev: sqlite:///./supportiq.db
# Set to use Postgres in Docker/Production: postgresql://postgres:postgres@localhost:5432/supportiq
DATABASE_URL=sqlite:///./supportiq.db

# --- Redis Configurations ---
# Leave empty to fall back to thread-safe in-memory cache during local development
REDIS_URL=redis://localhost:6379/0

# --- Vector Database Configurations ---
# If using chroma container: host=localhost, port=8001
# If empty, the backend falls back to local in-process PersistentClient at ./chroma_db
CHROMA_SERVER_HOST=
CHROMA_SERVER_PORT=8000
CHROMA_PERSIST_DIR=./chroma_db

# --- Frontend Configurations ---
# API URL for Next.js to reach FastAPI
NEXT_PUBLIC_API_URL=http://localhost:8000
